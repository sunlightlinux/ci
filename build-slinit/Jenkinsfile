pipeline {
    agent {
        node 'debian13-1'
    }

    parameters {
        string(
            name: 'SLINIT_TAG',
            defaultValue: 'v1.10.15',
            description: 'Tag from sunlightlinux/slinit (e.g. v1.10.15)'
        )
    }

    environment {
        SLINIT_TAG  = "${params.SLINIT_TAG}"
        GITHUB_URL  = "https://github.com/sunlightlinux/slinit/archive/refs/tags/${params.SLINIT_TAG}.tar.gz"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Build Dependencies') {
            steps {
                sh '''
                    apt-get update -y
                    apt-get install -y \
                        golang \
                        gcc \
                        wget
                '''
            }
        }

        stage('Download Source') {
            steps {
                sh """
                    rm -rf slinit slinit-${SLINIT_TAG} slinit-${SLINIT_TAG}.tar.gz
                    wget -q --show-progress -O slinit-${SLINIT_TAG}.tar.gz ${GITHUB_URL}
                    tar -xf slinit-${SLINIT_TAG}.tar.gz
                    mv slinit-\${SLINIT_TAG#v} slinit
                """
            }
        }

        stage('Static Analysis') {
            steps {
                sh '''
                    cd slinit
                    go vet ./...
                '''
            }
        }

        stage('Build (all commands)') {
            steps {
                sh """
                    cd slinit
                    mkdir -p bin
                    go build -ldflags "-X main.version=${SLINIT_TAG}" -o bin/ ./cmd/...
                    ls -la bin/
                """
            }
        }

        stage('Unit Tests (with race detector)') {
            steps {
                sh '''
                    cd slinit
                    go test -race -count=1 ./...
                '''
            }
        }

        stage('Smoke Tests') {
            steps {
                sh '''
                    cd slinit
                    ./bin/slinitctl --version
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'slinit/bin/*', fingerprint: true
            }
        }

        stage('Cleanup') {
            steps {
                cleanWs()
            }
        }
    }

    post {
        success {
            echo "slinit ${SLINIT_TAG} built successfully."
        }
        failure {
            echo "slinit build failed. Check logs: ${env.BUILD_URL}"
        }
    }
}
